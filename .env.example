# ── Copy this file to .env and fill in your values ──────────────
# NEVER commit .env to git

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Cloudflare R2 Backend Setup ─────────────────────────────────
# R2 keys are NEVER stored here in the frontend to prevent theft.
# Instead, you must set them as Edge Function Secrets in Supabase:
# Run: supabase secrets set R2_ACCESS_KEY_ID=xxx R2_SECRET_ACCESS_KEY=yyy R2_ENDPOINT=zzz R2_BUCKET_NAME=www
VITE_R2_PUBLIC_URL=https://pub-your-cloudflare-public-url.r2.dev

# Google OAuth (client-side, safe to expose but keep out of git)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# YouTube Data API v3
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Allowed Origins for Edge Function (comma-separated)
VITE_APP_ORIGIN=http://localhost:5173

# Groq API Key for Luna AI Assistant
VITE_GROQ_API_KEY=your_groq_api_key_here
